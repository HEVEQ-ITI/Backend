{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "StripePayment": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": "",
    "UseSimulatedCheckout": false,
    "SimulatedCheckoutBaseUrl": "http://localhost:4200/payment/checkout-simulated",
    "DefaultSuccessUrl": "http://localhost:4200/payment/success?session_id={CHECKOUT_SESSION_ID}",
    "DefaultCancelUrl": "http://localhost:4200/payment/cancel"
  },
  "PaymentPlatform": {
    "PlatformCommissionRate": 0.10,
    "DefaultEscrowHoldDays": 2
  },
  "BackgroundJobs": {
    "ProviderResponseSlaHours": 6,
    "CustomerCompletionAutoConfirmHours": 24,
    "EscrowReleaseAfterCompletionHours": 48,

    "MarketplaceAutoConfirmHours": 24,
    "MarketplaceEscrowReleaseHours": 48,

    "ProviderResponseSlaCron": "*/15 * * * *",
    "CustomerCompletionAutoConfirmCron": "*/15 * * * *",
    "EscrowReleaseAfterCompletionCron": "*/15 * * * *",

    "MarketplaceAutoConfirmCron": "*/15 * * * *",
    "MarketplaceEscrowReleaseCron": "*/15 * * * *"
  }
}
